generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DIRECT_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                      String           @id @default(cuid())
  name                    String?
  username                String?          @unique
  email                   String?          @unique
  emailVerified           DateTime?
  image                   String?
  password                String?
  rol                     String           @default("CUENTISTA")
  tinta                   Int              @default(10)
  puntos                  Int              @default(0)
  nivel                   String           @default("Principiante")
  casa                    String?
  generoFavorito          String?
  escritorFavorito        String?
  victorias               Int              @default(0)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  puntosCasa              Int              @default(0)
  lastParticipation       DateTime?
  streak                  Int              @default(0)
  bio                     String?
  nombre                  String?
  juramentoFirmado        Boolean          @default(false)
  isBanned                Boolean          @default(false)
  muteUntil               DateTime?
  especialidad            String?
  ultimoVotoReset         DateTime?
  votosHoy                Int              @default(0)
  founderNumber           Int?
  isFounder               Boolean          @default(false)
  stripeCustomerId        String?          @unique
  stripeSubscriptionId    String?          @unique
  subscriptionStatus      String           @default("INACTIVE")
  hasCompletedOnboarding  Boolean          @default(false)
  hasPerformedFirstAction Boolean          @default(false)
  lastDailyGift           DateTime?
  lossStreak              Int              @default(0)
  isFirstPurchase         Boolean          @default(true)
  totalSpent              Float            @default(0.0)
  perfilVistas            Int              @default(0)
  logros                  String[]         @default([])
  referredBy              String?
  referralRewardClaimed   Boolean          @default(false)
  activeBoost             Float?           @default(0)
  boostExpiresAt          DateTime?
  videoUploadsToday       Int              @default(0)
  lastVideoUpload         DateTime?
  
  // PRESTIGE IDENTITY
  activeFrameId           String?
  activeBadgeId           String?
  activeTitleId           String?

  // PRESTIGE ECONOMY (PHASE 14)
  rank                    String           @default("Aspirante")
  elo                     Int              @default(1000)
  precision               Float            @default(0)

  accounts                Account[]
  AuditLog                AuditLog[]
  juezDe                  Concurso[]       @relation("JuezConcurso")
  Draft                   Draft[]
  entradas                Entrada[]
  mensajes                Mensaje[]
  PurchaseIntent          PurchaseIntent[]
  sessions                Session[]
  TiendaItem              TiendaItem[]
  inventory               Inventory[]
  UserMision              UserMision[]
  Voto                    Voto[]
}

model GuestSession {
  id                String    @id @default(uuid())
  guestId           String    @unique
  interactionCount  Int       @default(0)
  firstActivityAt   DateTime  @default(now())
  ipHash            String?
  deviceHash        String?
  arenaDwellStart   DateTime?
  videoUploadsToday Int       @default(0)
  lastVideoUpload   DateTime?
  lastActivity      DateTime  @updatedAt

  @@index([guestId])
  @@index([deviceHash])
}

model RewardLog {
  id        String   @id @default(cuid())
  rewardKey String   @unique
  timestamp DateTime @default(now())
}

model Concurso {
  id               String    @id @default(cuid())
  titulo           String
  descripcion      String
  status           String    @default("waiting")
  startTime        DateTime?
  scheduledTime    DateTime?
  duration         Int       @default(5400)
  temaGeneral      String?
  temaExacto       String?
  categoria        String    @default("Principiante")
  costoTinta       Int       @default(0)
  isExamen         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  juezId           String?
  processed        Boolean   @default(false)
  tipo             String    @default("normal")
  maxParticipants  Int?
  prizePool        Int       @default(0)
  rewardMultiplier Float     @default(1.0)
  expiresAt        DateTime?
  isFlash          Boolean   @default(false)
  juez             User?     @relation("JuezConcurso", fields: [juezId], references: [id])
  Draft            Draft[]
  entradas         Entrada[]
}

model Entrada {
  id           String   @id @default(uuid())
  concursoId   String
  userId       String
  texto        String
  participante String
  suspicious   Boolean  @default(false)
  tabSwitches  Int      @default(0)
  puntajeTotal Float    @default(0)
  votos        Int      @default(0)
  timestamp    DateTime @default(now())
  updatedAt    DateTime @updatedAt @default(now())
  expertScore  Float    @default(0)
  popularScore Float    @default(0)
  isPublished  Boolean  @default(false)
  isFeatured   Boolean  @default(false)
  vistas       Int      @default(0)
  boostApplied Boolean  @default(false)
  videoUrl     String?
  judgeVideoUrl String?
  judgeComment String?
  videoStatus  String   @default("pending")
  concurso     Concurso @relation(fields: [concursoId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Voto         Voto[]

  @@unique([userId, concursoId])
  @@index([concursoId])
  @@index([userId])
}

model Mensaje {
  id        String   @id @default(cuid())
  userId    String
  texto     String
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TiendaItem {
  id             String     @id @default(cuid())
  nombre         String
  descripcion    String
  precio         Float
  precioTinta    Int?
  tipo           String     @default("tinta")
  cantidad       Int?
  imagenUrl      String?
  enlacePdf      String?
  enlaceEpub     String?
  disponible     Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  casaRequerida  String?
  categoria      String?    @default("Tinta")
  metadata       Json?
  rangoRequerido String?
  authorId       String?
  commission     Float      @default(0.20)
  stripePriceId  String?    @unique
  User           User?      @relation(fields: [authorId], references: [id])
  inventory      Inventory[]
}

model StoreItem {
  id             String      @id @default(cuid())
  name           String
  description    String?
  type           String      // "frame" | "badge" | "title" | "boost"
  priceTinta     Int         @default(0)
  priceMXN       Int?
  rarity         String      @default("common") // common, rare, epic, legendary
  stock          Int?        // Nullable means infinite
  isActive       Boolean     @default(true)
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  inventory      Inventory[]
}

model Inventory {
  id          String      @id @default(cuid())
  userId      String
  tiendaItemId String?
  storeItemId String?
  adquiridoEl DateTime    @default(now())
  cantidad    Int         @default(1)
  status      String      @default("active")
  
  // Prestige state
  equipped    Boolean     @default(false)
  equippedAt  DateTime?

  tiendaItem  TiendaItem? @relation(fields: [tiendaItemId], references: [id], onDelete: Cascade)
  storeItem   StoreItem?  @relation(fields: [storeItemId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tiendaItemId], name: "userId_tiendaItemId")
  @@unique([userId, storeItemId], name: "userId_storeItemId")
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  targetId  String?
  details   String?
  timestamp DateTime @default(now())
  User      User     @relation(fields: [adminId], references: [id])
}

model Draft {
  id          String    @id @default(uuid())
  concursoId  String
  userId      String
  username    String?
  texto       String
  suspicious  Boolean   @default(false)
  tabSwitches Int       @default(0)
  updatedAt   DateTime
  startedAt   DateTime?
  Concurso    Concurso  @relation(fields: [concursoId], references: [id], onDelete: Cascade)
  User        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, concursoId])
}

model GlobalSettings {
  id               String   @id @default("singleton")
  gloriaMultiplier Float    @default(1.0)
  inkBonus         Int      @default(0)
  isEventActive    Boolean  @default(false)
  eventName        String?
  lastUpdate       DateTime
  lastWeeklyWinner String?
}

model Mision {
  id           String       @id @default(cuid())
  titulo       String
  descripcion  String
  tipo         String
  meta         Int
  recompensa   Json
  rareza       String       @default("COMUN")
  isPersistent Boolean      @default(false)
  costoTinta   Int          @default(0)
  UserMision   UserMision[]
}

model PurchaseIntent {
  id                String   @id
  userId            String
  contestId         String?
  itemId            String?
  tintaMissing      Int
  intentLevel       Int      @default(1)
  contexto          Json?
  timestamp         DateTime @default(now())
  updatedAt         DateTime
  wantsNotification Boolean  @default(false)
  User              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserMision {
  id          String   @id @default(cuid())
  userId      String
  misionId    String
  progreso    Int      @default(0)
  completada  Boolean  @default(false)
  reclamada   Boolean  @default(false)
  fechaInicio DateTime @default(now())
  ultimaAct   DateTime
  aceptada    Boolean  @default(false)
  fallida     Boolean  @default(false)
  Mision      Mision   @relation(fields: [misionId], references: [id], onDelete: Cascade)
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, misionId])
}

model Voto {
  id           String   @id @default(cuid())
  userId       String
  entradaId    String
  tipo         String   @default("POPULAR")
  tecnica      Int?     @default(0)
  creatividad  Int?     @default(0)
  impacto      Int?     @default(0)
  mencionHonor Boolean? @default(false)
  comentario   String?
  timestamp    DateTime @default(now())
  Entrada      Entrada  @relation(fields: [entradaId], references: [id], onDelete: Cascade)
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entradaId, tipo])
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String?
  timestamp DateTime @default(now())
}
model StripeEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  createdAt DateTime @default(now())
}
