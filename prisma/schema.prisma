// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DIRECT_URL")
  directUrl = env("DIRECT_URL")
}

// NextAuth Models Core
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Cuentistas Web Data Models
model User {
  id               String    @id @default(cuid())
  name             String?
  username         String?   @unique
  email            String?   @unique
  emailVerified    DateTime?
  image            String?
  password         String?   // For Credentials provider (hashed)
  
  // Custom Fields
  nombre           String?   // Alias para compatibilidad
  bio              String?   // Biografía del autor
  rol              String    @default("Escritor")
  tinta            Int       @default(60)
  puntos           Int       @default(0) // XP
  puntosCasa       Int       @default(0) // Para el ranking mensual de casas
  nivel            String    @default("Principiante")
  casa             String?
  generoFavorito   String?
  escritorFavorito String?
  victorias        Int       @default(0)
  // Streak System
  lastParticipation DateTime?
  streak           Int       @default(0)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  accounts         Account[]
  sessions         Session[]
  entradas         Entrada[] // Su participacion en concursos
  mensajes         Mensaje[] // Comunidad
  juezDe           Concurso[] @relation("JuezConcurso")
  itemsAdquiridos  UserItem[] // Libros y objetos comprados
}

model Concurso {
  id            String    @id @default(cuid())
  titulo        String
  descripcion   String
  status        String    @default("waiting") // waiting, active, finished
  startTime     DateTime?
  scheduledTime DateTime?
  duration      Int       @default(5400) // 1.5 hours in seconds
  temaGeneral   String?
  temaExacto    String?
  categoria     String    @default("Principiante")
  costoTinta    Int       @default(0)
  isExamen      Boolean   @default(false)
  processed     Boolean   @default(false) // Para la Cosecha de premios
  tipo          String    @default("normal") // normal, casa
  juezId        String?
  juez          User?     @relation("JuezConcurso", fields: [juezId], references: [id])
  createdAt     DateTime  @default(now())

  entradas      Entrada[]
}

model Entrada {
  id            String    @id @default(cuid())
  concursoId    String
  userId        String
  texto         String
  participante  String    // Saved explicitly in case user changes name
  suspicious    Boolean   @default(false)
  tabSwitches   Int       @default(0)
  puntajeTotal  Float     @default(0)
  votos         Int       @default(0)
  timestamp     DateTime  @default(now())

  concurso      Concurso  @relation(fields: [concursoId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([concursoId])
  @@index([userId])
}

model Mensaje {
  id            String    @id @default(cuid())
  userId        String
  texto         String
  timestamp     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// El Gran Mercado
model TiendaItem {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String
  precio      Float
  precioTinta Int?     // Opción de compra con Tinta/XP si aplica
  tipo        String   @default("tinta") // tinta, libro, objeto
  cantidad    Int?     // Para packs de tinta (ej: +50)
  imagenUrl   String?
  enlacePdf   String?  // Para libros
  enlaceEpub  String?  // Para libros
  disponible  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  propietarios UserItem[]
}

model UserItem {
  id          String   @id @default(cuid())
  userId      String
  itemId      String
  adquiridoEl DateTime @default(now())
  
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  item        TiendaItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId]) // Evitar duplicados de compra del mismo item
}
